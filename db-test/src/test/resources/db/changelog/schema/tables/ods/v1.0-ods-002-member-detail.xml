<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        SCHEMA : ods
        TABLE  : ods.member_detail
        Version: v1.0
        Author : upesh.karki
        Desc   : Extended profile info submitted by the user. 1-to-1 with ods.member.
    -->

    <changeSet id="v1.0-ods-tbl-002-member-detail" author="upesh.karki">
        <createTable schemaName="ods" tableName="member_detail" remarks="Extended user profile — input from profile setup form">
            <column name="id" type="BIGINT" defaultValueSequenceNext="ods.member_detail_id_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_ods_member_detail"/>
            </column>
            <column name="member_id"    type="BIGINT" remarks="FK → ods.member.id">
                <constraints nullable="false"
                             foreignKeyName="fk_ods_member_detail_member"
                             references="ods.member(id)"/>
            </column>
            <column name="occupation"   type="VARCHAR(100)"/>
            <column name="address1"     type="VARCHAR(255)"/>
            <column name="address2"     type="VARCHAR(255)"/>
            <column name="city"         type="VARCHAR(100)"/>
            <column name="country"      type="VARCHAR(100)"  remarks="FK → ref.country.code (future)"/>
            <column name="zip_code"     type="VARCHAR(20)"/>
            <column name="phone_number" type="VARCHAR(30)"/>
            <column name="created_at"   type="TIMESTAMP"    defaultValueComputed="NOW()"/>
            <column name="updated_at"   type="TIMESTAMP"    defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
