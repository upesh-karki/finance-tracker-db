<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        SCHEMA : rpt
        TABLE  : rpt.savings_recommendation
        Version: v1.0
        Author : upesh.karki
        Desc   : Output from the savings recommendation engine.
                 Populated by SavingsService business logic, not by user input.
                 Each run creates a new snapshot — history is preserved.
    -->

    <changeSet id="v1.0-rpt-tbl-001-savings-recommendation" author="upesh.karki">
        <createTable schemaName="rpt" tableName="savings_recommendation"
                     remarks="Output of the savings recommendation engine — generated by business logic">
            <column name="id" type="BIGINT" defaultValueSequenceNext="rpt.savings_recommendation_id_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_rpt_savings_recommendation"/>
            </column>
            <column name="member_id"              type="BIGINT"        remarks="FK → ods.member.id">
                <constraints nullable="false"
                             foreignKeyName="fk_rpt_savings_rec_member"
                             references="ods.member(id)"/>
            </column>
            <column name="total_income"           type="NUMERIC(10,2)" remarks="Monthly income used in this analysis"/>
            <column name="total_expenses"         type="NUMERIC(10,2)" remarks="Total expenses analysed"/>
            <column name="current_savings_rate"   type="NUMERIC(5,2)"  remarks="(income - expenses) / income * 100"/>
            <column name="top_category_1"         type="VARCHAR(50)"   remarks="Highest spend category"/>
            <column name="top_category_1_amount"  type="NUMERIC(10,2)"/>
            <column name="top_category_2"         type="VARCHAR(50)"   remarks="Second highest spend category"/>
            <column name="top_category_2_amount"  type="NUMERIC(10,2)"/>
            <column name="top_category_3"         type="VARCHAR(50)"   remarks="Third highest spend category"/>
            <column name="top_category_3_amount"  type="NUMERIC(10,2)"/>
            <column name="months_at_current_rate" type="INT"           remarks="Months to goal at current savings rate"/>
            <column name="months_with_10pct_cut"  type="INT"           remarks="Months to goal with 10% reduction in top category"/>
            <column name="months_with_20pct_cut"  type="INT"           remarks="Months to goal with 20% reduction in top category"/>
            <column name="recommendation_text"    type="TEXT"          remarks="Human-readable advice generated by engine"/>
            <column name="generated_at"           type="TIMESTAMP"     defaultValueComputed="NOW()"
                     remarks="When this recommendation snapshot was produced"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
