<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        SCHEMA : ref
        TABLE  : ref.expense_category
        Version: v1.0
        Author : upesh.karki
        Desc   : Valid expense category codes. App enum must stay in sync with this table.
                 Read-only from application code.
    -->

    <changeSet id="v1.0-ref-tbl-001-expense-category" author="upesh.karki">
        <createTable schemaName="ref" tableName="expense_category" remarks="Valid expense category reference data">
            <column name="code"        type="VARCHAR(50)"   remarks="Category code used in ods.expense.category">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_ref_expense_category"/>
            </column>
            <column name="label"       type="VARCHAR(100)"  remarks="Human-readable display label">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"  remarks="What types of expenses belong here"/>
            <column name="icon"        type="VARCHAR(50)"   remarks="Optional UI icon name"/>
            <column name="sort_order"  type="INT"           defaultValueNumeric="0"/>
            <column name="is_active"   type="BOOLEAN"       defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <changeSet id="v1.0-ref-dml-001-expense-category-seed" author="upesh.karki">
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="FOOD"/>
            <column name="label" value="Food &amp; Dining"/>
            <column name="description" value="Groceries, restaurants, coffee, takeout"/>
            <column name="sort_order" valueNumeric="1"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="TRANSPORT"/>
            <column name="label" value="Transport"/>
            <column name="description" value="Public transit, gas, parking, rideshare"/>
            <column name="sort_order" valueNumeric="2"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="UTILITIES"/>
            <column name="label" value="Utilities"/>
            <column name="description" value="Electricity, water, gas, internet, phone"/>
            <column name="sort_order" valueNumeric="3"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="SUBSCRIPTIONS"/>
            <column name="label" value="Subscriptions"/>
            <column name="description" value="Streaming services, software, memberships"/>
            <column name="sort_order" valueNumeric="4"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="ENTERTAINMENT"/>
            <column name="label" value="Entertainment"/>
            <column name="description" value="Movies, events, hobbies, games"/>
            <column name="sort_order" valueNumeric="5"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="TRAVEL"/>
            <column name="label" value="Travel"/>
            <column name="description" value="Flights, hotels, vacation expenses"/>
            <column name="sort_order" valueNumeric="6"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="HEALTH"/>
            <column name="label" value="Health &amp; Fitness"/>
            <column name="description" value="Gym, pharmacy, medical, dental"/>
            <column name="sort_order" valueNumeric="7"/>
        </insert>
        <insert schemaName="ref" tableName="expense_category">
            <column name="code" value="OTHER"/>
            <column name="label" value="Other"/>
            <column name="description" value="Anything that does not fit another category"/>
            <column name="sort_order" valueNumeric="8"/>
        </insert>
        <rollback>
            <delete schemaName="ref" tableName="expense_category"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
