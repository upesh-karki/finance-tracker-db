<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        ╔══════════════════════════════════════════════════════════════╗
        ║           FINANCE TRACKER — MASTER CHANGELOG                ║
        ╠══════════════════════════════════════════════════════════════╣
        ║  Single entry point for all database changes.               ║
        ║  Liquibase tracks every applied changeSet in:               ║
        ║    dbutils.changelog_audit  (audit trail)                   ║
        ║    dbutils.databasechangeloglock  (concurrency lock)        ║
        ║                                                             ║
        ║  Execution order (DO NOT reorder):                          ║
        ║    1. dbutils — audit schema + tracking table               ║
        ║    2. ref     — reference/lookup tables + seed data         ║
        ║    3. ods     — user data tables (FK → ref)                 ║
        ║    4. rpt     — output/reporting tables (FK → ods)          ║
        ║                                                             ║
        ║  How to make a DB change:                                   ║
        ║    - Edit/create the SQL file in the relevant schema dir    ║
        ║    - For DDL: bump the changeSet id in its changelog XML    ║
        ║    - For functions/views/seed: runOnChange=true handles it  ║
        ║    - Run: liquibase update                                  ║
        ╚══════════════════════════════════════════════════════════════╝
    -->

    <!-- 1. dbutils — audit schema (must be first) -->
    <include file="dbutils/dbutils-master-changelog.xml"         relativeToChangelogFile="true"/>

    <!-- 2. ref — reference data (no FK deps on ods) -->
    <include file="schema/ref/ref-master-changelog.xml"          relativeToChangelogFile="true"/>

    <!-- 3. ods — user data (FK → ref) -->
    <include file="schema/ods/ods-master-changelog.xml"          relativeToChangelogFile="true"/>

    <!-- 4. rpt — reporting/output tables (FK → ods) -->
    <include file="schema/rpt/rpt-master-changelog.xml"          relativeToChangelogFile="true"/>

</databaseChangeLog>
