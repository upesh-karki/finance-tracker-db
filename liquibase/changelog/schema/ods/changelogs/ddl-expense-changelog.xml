<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="ods-v1.0-ddl-expense" author="upesh.karki">
        <sqlFile path="../ddl/expense.sql"
                 relativeToChangelogFile="true"
                 splitStatements="false"
                 stripComments="false"/>
        <rollback>DROP TABLE IF EXISTS ods.expense CASCADE;</rollback>
    </changeSet>

    <!-- v1.1: adds institution_name — tracks which bank this transaction came from -->
    <changeSet id="ods-v1.1-ddl-expense-add-institution-name" author="upesh.karki">
        <sql>ALTER TABLE ods.expense ADD COLUMN IF NOT EXISTS institution_name VARCHAR(100);</sql>
        <rollback>ALTER TABLE ods.expense DROP COLUMN IF EXISTS institution_name;</rollback>
    </changeSet>

</databaseChangeLog>
