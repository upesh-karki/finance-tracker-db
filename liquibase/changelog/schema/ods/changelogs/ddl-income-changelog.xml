<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="ods-v1.0-ddl-income" author="upesh.karki">
        <sqlFile path="../ddl/income.sql"
                 relativeToChangelogFile="true"
                 splitStatements="false"
                 stripComments="false"/>
        <rollback>DROP TABLE IF EXISTS ods.income CASCADE;</rollback>
    </changeSet>

    <!-- v1.1: adds institution_name — tracks which bank this income came from -->
    <changeSet id="ods-v1.1-ddl-income-add-institution-name" author="upesh.karki">
        <sql>ALTER TABLE ods.income ADD COLUMN IF NOT EXISTS institution_name VARCHAR(100);</sql>
        <rollback>ALTER TABLE ods.income DROP COLUMN IF EXISTS institution_name;</rollback>
    </changeSet>

</databaseChangeLog>
