<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="ref-v1.0-ddl-income-category" author="upesh.karki">
        <sqlFile path="../ddl/income_category.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <rollback>DROP TABLE IF EXISTS ref.income_category CASCADE;</rollback>
    </changeSet>

    <!-- v1.1: adds sort_order column to existing installs -->
    <changeSet id="ref-v1.1-ddl-income-category-add-sort-order" author="upesh.karki">
        <sql>ALTER TABLE ref.income_category ADD COLUMN IF NOT EXISTS sort_order INT DEFAULT 0;</sql>
        <rollback><!-- non-destructive --></rollback>
    </changeSet>
</databaseChangeLog>
