<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="ref-v1.0-ddl-account-type" author="upesh.karki">
        <sqlFile path="../ddl/account_type.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <rollback>DROP TABLE IF EXISTS ref.account_type CASCADE;</rollback>
    </changeSet>

    <!-- v1.1: adds sort_order + description columns to existing installs -->
    <changeSet id="ref-v1.1-ddl-account-type-add-cols" author="upesh.karki">
        <sql>
            ALTER TABLE ref.account_type ADD COLUMN IF NOT EXISTS sort_order  INT          DEFAULT 0;
            ALTER TABLE ref.account_type ADD COLUMN IF NOT EXISTS description VARCHAR(255);
        </sql>
        <rollback><!-- non-destructive --></rollback>
    </changeSet>
</databaseChangeLog>
