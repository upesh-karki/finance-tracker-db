<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="ref-v1.0-ddl-transaction-type" author="upesh.karki">
        <sqlFile path="../ddl/transaction_type.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <rollback>DROP TABLE IF EXISTS ref.transaction_type CASCADE;</rollback>
    </changeSet>

    <!-- v1.1: adds sort_order + is_active to existing installs -->
    <changeSet id="ref-v1.1-ddl-transaction-type-add-cols" author="upesh.karki">
        <sql>
            ALTER TABLE ref.transaction_type ADD COLUMN IF NOT EXISTS sort_order INT     DEFAULT 0;
            ALTER TABLE ref.transaction_type ADD COLUMN IF NOT EXISTS is_active  BOOLEAN DEFAULT TRUE;
        </sql>
        <rollback><!-- non-destructive --></rollback>
    </changeSet>
</databaseChangeLog>
