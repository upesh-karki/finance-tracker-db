<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        TABLE: savings_goal
        Version : v1.0
        Author  : upesh.karki
        Desc    : Member savings goals. Used by the recommendation engine.
                  status values: ACTIVE | ACHIEVED | CANCELLED
    -->

    <changeSet id="v1.0-tbl-004-create-savings-goal" author="upesh.karki">
        <createTable tableName="savings_goal" remarks="Member savings goals">
            <column name="id" type="BIGINT" defaultValueSequenceNext="savings_goal_id_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_savings_goal"/>
            </column>
            <column name="member_id"              type="BIGINT"        remarks="FK to member">
                <constraints nullable="false"
                             foreignKeyName="fk_savings_goal_member"
                             references="member(id)"/>
            </column>
            <column name="goal_name"              type="VARCHAR(255)"  remarks="Name of the goal">
                <constraints nullable="false"/>
            </column>
            <column name="target_amount"          type="NUMERIC(10,2)" remarks="Total amount to save"/>
            <column name="current_amount"         type="NUMERIC(10,2)" defaultValueNumeric="0"
                     remarks="Amount saved so far"/>
            <column name="monthly_savings_target" type="NUMERIC(10,2)" remarks="Target monthly contribution"/>
            <column name="income"                 type="NUMERIC(10,2)" remarks="Member monthly income"/>
            <column name="target_date"            type="DATE"          remarks="Goal completion target date"/>
            <column name="status"                 type="VARCHAR(20)"   defaultValue="ACTIVE"
                     remarks="ACTIVE | ACHIEVED | CANCELLED"/>
            <column name="created_at"             type="TIMESTAMP"     defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
