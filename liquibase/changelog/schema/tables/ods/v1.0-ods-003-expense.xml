<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        SCHEMA : ods
        TABLE  : ods.expense
        Version: v1.0
        Author : upesh.karki
        Desc   : Expenses logged by the user. Input from the expense entry form.
                 category is validated against ref.expense_category.
    -->

    <changeSet id="v1.0-ods-tbl-003-expense" author="upesh.karki">
        <createTable schemaName="ods" tableName="expense" remarks="User-submitted expense records">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_ods_expense"/>
            </column>
            <column name="member_id"    type="BIGINT"        remarks="FK → ods.member.id">
                <constraints nullable="false"
                             foreignKeyName="fk_ods_expense_member"
                             references="ods.member(id)"/>
            </column>
            <column name="expense_name" type="VARCHAR(255)"  remarks="User-provided expense label">
                <constraints nullable="false"/>
            </column>
            <column name="amount"       type="NUMERIC(10,2)" remarks="Expense amount">
                <constraints nullable="false"/>
            </column>
            <column name="category"     type="VARCHAR(50)"
                     remarks="FK → ref.expense_category.code. FOOD|TRANSPORT|UTILITIES|SUBSCRIPTIONS|ENTERTAINMENT|TRAVEL|HEALTH|OTHER"/>
            <column name="description"  type="VARCHAR(500)"  remarks="Optional user note"/>
            <column name="expense_date" type="DATE"          remarks="Date the expense occurred">
                <constraints nullable="false"/>
            </column>
            <column name="created_at"   type="TIMESTAMP"     defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
