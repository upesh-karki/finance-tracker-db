<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        SCHEMA : ods
        TABLE  : ods.member
        Version: v1.0
        Author : upesh.karki
        Desc   : Core user accounts. Input from registration form.
    -->

    <changeSet id="v1.0-ods-tbl-001-member" author="upesh.karki">
        <createTable schemaName="ods" tableName="member" remarks="Registered user accounts — input from user registration">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_ods_member"/>
            </column>
            <column name="first_name"     type="VARCHAR(100)"  remarks="User first name"/>
            <column name="last_name"      type="VARCHAR(100)"  remarks="User last name"/>
            <column name="email"          type="VARCHAR(255)"  remarks="Unique login email">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_ods_member_email"/>
            </column>
            <column name="password"       type="VARCHAR(255)"  remarks="Hashed password">
                <constraints nullable="false"/>
            </column>
            <column name="username"       type="VARCHAR(100)"  remarks="Unique username">
                <constraints unique="true" uniqueConstraintName="uq_ods_member_username"/>
            </column>
            <column name="profile_status" type="VARCHAR(20)"   defaultValue="ACTIVE"
                     remarks="FK → ref.profile_status. ACTIVE|INACTIVE|SUSPENDED"/>
            <column name="created_at"     type="TIMESTAMP"     defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
