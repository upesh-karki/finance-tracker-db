<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.1-ods-004-alter-expense-add-account" author="upesh.karki">
        <addColumn schemaName="ods" tableName="expense">
            <column name="account_id" type="bigint">
                <constraints foreignKeyName="fk_ods_expense_account" references="ods.financial_account(id)"/>
            </column>
        </addColumn>
        <addColumn schemaName="ods" tableName="expense">
            <column name="statement_id" type="bigint">
                <constraints foreignKeyName="fk_ods_expense_statement" references="ods.account_statement(id)"/>
            </column>
        </addColumn>
        <addColumn schemaName="ods" tableName="expense">
            <column name="transaction_type" type="varchar(30)" defaultValue="DEBIT"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
