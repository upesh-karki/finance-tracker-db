<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        TABLE: member_detail
        Version : v1.0
        Author  : upesh.karki
        Desc    : Extended profile info for a member. 1-to-1 with member.
    -->

    <changeSet id="v1.0-tbl-002-create-member-detail" author="upesh.karki">
        <createTable tableName="member_detail" remarks="Extended member profile details">
            <column name="id" type="BIGINT" defaultValueSequenceNext="member_detail_id_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_member_detail"/>
            </column>
            <column name="member_id"     type="BIGINT"      remarks="FK to member">
                <constraints nullable="false"
                             foreignKeyName="fk_member_detail_member"
                             references="member(id)"/>
            </column>
            <column name="occupation"    type="VARCHAR(100)"/>
            <column name="address1"      type="VARCHAR(255)"/>
            <column name="address2"      type="VARCHAR(255)"/>
            <column name="city"          type="VARCHAR(100)"/>
            <column name="country"       type="VARCHAR(100)"/>
            <column name="zip_code"      type="VARCHAR(20)"/>
            <column name="phone_number"  type="VARCHAR(30)"/>
            <column name="profile_status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
            <column name="created_at"    type="TIMESTAMP"   defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
